        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    AIRPORTS {\n        bigserial id PK\n        varchar_255 name \&quot;NOT NULL\&quot;\n        varchar_3 iata_code \&quot;NOT NULL, UNIQUE\&quot;\n        varchar_100 city \&quot;NOT NULL\&quot;\n        varchar_100 country \&quot;NOT NULL\&quot;\n    }\n\n    AIRPLANES {\n        bigserial id PK\n        varchar_100 model \&quot;NOT NULL\&quot;\n        varchar_20 tail_number \&quot;NOT NULL, UNIQUE\&quot;\n        integer capacity \&quot;NOT NULL, CHECK (capacity &gt; 0)\&quot;\n        varchar_100 airline \&quot;NOT NULL\&quot;\n    }\n\n    USERS {\n        bigserial id PK\n        varchar_100 email \&quot;NOT NULL, UNIQUE\&quot;\n        varchar_255 password \&quot;NOT NULL\&quot;\n        varchar_50 role \&quot;NOT NULL (ADMIN, PASSENGER)\&quot;\n        varchar_100 first_name \&quot;NOT NULL\&quot;\n        varchar_100 last_name \&quot;NOT NULL\&quot;\n    }\n\n    RESERVATIONS {\n        bigserial id PK\n        bigint passenger_id FK \&quot;Users(id) - NOT NULL\&quot;\n        bigint airplane_id FK \&quot;Airplanes(id) - NOT NULL\&quot;\n        bigint departure_airport_id FK \&quot;Airports(id) - NOT NULL\&quot;\n        bigint arrival_airport_id FK \&quot;Airports(id) - NOT NULL\&quot;\n        timestamp flight_date \&quot;NOT NULL\&quot;\n        varchar_10 seat_number \&quot;NOT NULL\&quot;\n        varchar_20 status \&quot;NOT NULL (PENDING, CONFIRMED, CANCELED)\&quot;\n    }\n\n    USERS ||--o{ RESERVATIONS : \&quot;makes\&quot;\n    AIRPLANES ||--o{ RESERVATIONS : \&quot;assigned_to\&quot;\n    AIRPORTS ||--o{ RESERVATIONS : \&quot;departs_from\&quot;\n    AIRPORTS ||--o{ RESERVATIONS : \&quot;arrives_at\&quot;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="A60KOyUuAI4OGnVrEaiM-1">
