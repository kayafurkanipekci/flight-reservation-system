# This is an example env file. Copy this file to .env and fill in the values. Please rename the file .env.example to .env and do not commit it.

# --- Database ---
POSTGRES_PASSWORD=

# --- pgAdmin (local dev tool) ---
PGADMIN_DEFAULT_PASSWORD=

# --- JWT ---
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# --- Redis ---
# Leave host/port as-is for docker-compose; only needed if overriding for a hosted Redis
SPRING_DATA_REDIS_HOST=flight-redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# --- Mail (SMTP) ---
# Leave as-is for local docker-compose (uses MailHog); override for a real SMTP provider in production
SPRING_MAIL_HOST=flight-mailhog
SPRING_MAIL_PORT=1025

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Frontend build-time API URL (only used when building the frontend image) ---
VITE_API_URL=http://localhost:8081/api